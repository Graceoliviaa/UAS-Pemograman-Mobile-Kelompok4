<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <EditText android:id="@+id/etDocName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nama Dokumen" />
    <EditText android:id="@+id/etDocPath" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Path/Link Dokumen" android:layout_marginTop="16dp" />
    <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Simpan" android:layout_marginTop="24dp" />
</LinearLayout>